[Unit]
Description=CTF Player Instance API
After=network.target docker.service
Requires=docker.service

[Service]
Type=simple
EnvironmentFile=/etc/ctf/orchestrator.env
ExecStart=/usr/bin/python3 /opt/ctf/orchestrator/player-instance-api.py
Restart=always
RestartSec=3
User=root

[Install]
WantedBy=multi-user.target
