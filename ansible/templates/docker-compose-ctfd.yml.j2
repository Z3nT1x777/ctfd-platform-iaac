services:
  ctfd:
    build:
      context: /vagrant/ansible/docker/ctfd
    image: ctfd-custom:{{ ctfd_version }}
    pull_policy: never
    container_name: ctfd
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{ ctfd_internal_port }}:8000"
    environment:
      - DATABASE_URL=mysql+pymysql://{{ DB_USER }}:{{ db_password_effective }}@db/{{ DB_NAME }}
      - REDIS_URL=redis://cache:6379
      - SECRET_KEY=${CTFD_SECRET_KEY:-change-me}
      - ORCHESTRATOR_API_URL=http://host.docker.internal:{{ orchestrator_proxy_listen_port }}
      - ORCHESTRATOR_API_TOKEN={{ orchestrator_api_token_effective }}
      - ORCHESTRATOR_SIGNING_SECRET={{ orchestrator_signing_secret_effective }}
      - ORCHESTRATOR_WEBHOOK_TOKEN={{ orchestrator_ctfd_webhook_token_effective }}
      - ORCHESTRATOR_TEAM_MAX_ACTIVE={{ orchestrator_team_max_active }}
      - ORCHESTRATOR_HTTP_TIMEOUT_SEC={{ orchestrator_http_timeout_sec }}
      - ORCHESTRATOR_HTTP_ACTION_TIMEOUT_SEC={{ orchestrator_http_action_timeout_sec }}
    extra_hosts:
      - "host.docker.internal:host-gateway"
    volumes:
      - ./ctfd_data:/var/log/CTFd
      - ./ctfd_uploads:/var/uploads
      - /var/run/docker.sock:/var/run/docker.sock
      - /vagrant/scripts/ctfd-orchestrator-plugin:/opt/CTFd/CTFd/plugins/ctfd_orchestrator_plugin
      - /vagrant/challenges:/vagrant/challenges:ro
    depends_on:
      - db
      - cache
    networks:
      - ctfd_network

  db:
    image: mariadb:10.11
    container_name: ctfd_db
    restart: unless-stopped
    environment:
      - MYSQL_ROOT_PASSWORD={{ db_root_password_effective }}
      - MYSQL_DATABASE={{ DB_NAME }}
      - MYSQL_USER={{ DB_USER }}
      - MYSQL_PASSWORD={{ db_password_effective }}

    volumes:
      - ./db_data:/var/lib/mysql
    networks:
      - ctfd_network

  cache:
    image: redis:7-alpine
    container_name: ctfd_cache
    restart: unless-stopped
    networks:
      - ctfd_network

networks:
  ctfd_network:
    driver: bridge
